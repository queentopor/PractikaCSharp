<Window x:Class="DocumentVersionControl.VersionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление версии" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Автор:" Margin="5" FontWeight="Bold"/>
        <TextBox x:Name="AuthorTextBox" Grid.Row="1" Margin="5" Height="30"/>

        <Label Grid.Row="2" Content="Описание изменений:" Margin="5" FontWeight="Bold"/>
        <TextBox x:Name="DescriptionTextBox" Grid.Row="3" Margin="5" Height="80" 
                 TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="OK" Width="80" Height="30" Margin="5" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="80" Height="30" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>