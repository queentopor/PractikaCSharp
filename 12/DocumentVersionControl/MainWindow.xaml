<Window x:Class="DocumentVersionControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Контроль версий документов" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="0,0,0,-92">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Контроль версий документов" 
                   FontSize="24" FontWeight="Bold" Foreground="#2C3E50" 
                   HorizontalAlignment="Center" Margin="10"/>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" 
                    CornerRadius="5" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Структура документов" FontWeight="Bold" 
                               Margin="10" FontSize="14"/>
                    <TreeView x:Name="FoldersTreeView" Margin="5" Height="450"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <StackPanel Margin="1,-9,-1,9">
                    <TextBlock Text="Версии документа" FontWeight="Bold" 
                               Margin="10" FontSize="14"/>

                    <Border Background="#ECF0F1" Margin="10" CornerRadius="5" Padding="10">
                        <TextBlock x:Name="SelectedDocumentInfo" Text="Документ не выбран"/>
                    </Border>

                    <DataGrid x:Name="VersionsGrid" AutoGenerateColumns="True" Margin="10" Height="350"/>

                    <Button x:Name="AddVersionButton" Content="Добавить версию" 
                            Width="150" Height="35" Margin="10" HorizontalAlignment="Right"
                            Click="AddVersionButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>